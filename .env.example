# ──────────────────────────────────────────────
# Talos Configuration
# Copy to .env and fill in the values
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
TALOS_HOST=0.0.0.0
TALOS_PORT=3000

# Domain (optional — enables HTTPS via Let's Encrypt)
# Set this if you have a domain pointed at this server.
# Leave empty for IP-only access (http://<your-ip>:3000).
# TALOS_DOMAIN=talos.example.com
# TALOS_ACME_EMAIL=admin@example.com

# ── Database ──────────────────────────────────
TALOS_DB_PATH=data/talos.db

# ── Authentication ────────────────────────────
# REQUIRED — session signing secret (min 32 chars recommended)
TALOS_SESSION_SECRET=change-me-to-a-random-secret

# Session max age in seconds (default: 604800 = 7 days)
TALOS_SESSION_MAX_AGE=604800

# ── Docker ────────────────────────────────────
TALOS_DOCKER_HOST=unix:///var/run/docker.sock
TALOS_DOCKER_NETWORK=talos

# ── Traefik ───────────────────────────────────
TALOS_TRAEFIK_IMAGE=traefik:v3.0
TALOS_TRAEFIK_DASHBOARD=false
TALOS_TRAEFIK_CONFIG_DIR=data/traefik/config
TALOS_TRAEFIK_DATA_DIR=data/traefik/data

# ── Encryption ────────────────────────────────
# Base64-encoded 32-byte key for AES-256-GCM credential encryption.
# Auto-generated on first run if left empty and written back to .env.
# Generate manually: openssl rand -base64 32
# TALOS_ENCRYPTION_KEY=

# ── Backup ─────────────────────────────────────
# Directory for storing backup files (default: data/backups)
# TALOS_BACKUP_DIR=data/backups

# ── GitHub App (optional) ────────────────────
# Create at: https://github.com/settings/apps/new
# Or use the setup wizard: /settings/github/setup
# TALOS_GITHUB_WEBHOOK_SECRET=
# TALOS_GITHUB_APP_ID=0
# TALOS_GITHUB_APP_SLUG=talos-deploy
# TALOS_GITHUB_APP_PRIVATE_KEY=
# TALOS_GITHUB_APP_CLIENT_ID=
# TALOS_GITHUB_APP_CLIENT_SECRET=
